# ════════════════════════════════════════════════════════════
#  PropAlgo Trading Dashboard — Environment Configuration
#  Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────
APP_NAME=PropAlgo Trading Dashboard
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# ─── Trading Engine ───────────────────────────────────────
INITIAL_BALANCE=10000.0
LIVE_SCAN_INTERVAL=60
DATA_PERIOD_LIVE=3mo
DATA_PERIOD_BACKTEST=1y
DATA_INTERVAL=1d

# ─── Nginx ────────────────────────────────────────────────
NGINX_HTTP_PORT=80

# ─── Telegram ─────────────────────────────────────────────
# Get token from @BotFather, chat ID from @userinfobot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (Gmail SMTP) ───────────────────────────────────
# Use Gmail App Passwords (not your real password)
# https://myaccount.google.com/apppasswords
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
EMAIL_RECIPIENTS=[]

# ─── SMS (Twilio) ─────────────────────────────────────────
# https://www.twilio.com/console
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_RECIPIENTS=[]

# ─── Notification Settings ────────────────────────────────
NOTIFY_ON_SIGNAL=true
NOTIFY_ON_RISK_ALERT=true
MIN_CONFIDENCE_NOTIFY=0.65

# ─── Auth ─────────────────────────────────────────────────
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123
JWT_EXPIRE_MINUTES=1440

# ─── Redis ────────────────────────────────────────────────
USE_REDIS=true
# Automatically set by docker-compose; change for external Redis
REDIS_URL=redis://redis:6379/0

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/prop_algo.db
